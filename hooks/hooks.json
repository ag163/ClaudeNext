{
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require((process.env.CLAUDE_PLUGIN_ROOT || process.env.CODEX_PLUGIN_ROOT) + '/scripts/check-429.js')\"",
            "commandWindows": "node -e \"require((process.env.CLAUDE_PLUGIN_ROOT || process.env.CODEX_PLUGIN_ROOT) + '/scripts/check-429.js')\"",
            "timeout": 30,
            "statusMessage": "Checking for rate-limit interruption"
          }
        ]
      }
    ]
  }
}
